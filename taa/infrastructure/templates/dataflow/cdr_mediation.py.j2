import argparse
import csv
import io
import json
import logging
from datetime import datetime

import apache_beam as beam
from apache_beam.options.pipeline_options import PipelineOptions, StandardOptions
from apache_beam.io.gcp.bigquery import WriteToBigQuery, BigQueryDisposition
from apache_beam.metrics import Metrics
from apache_beam.transforms.window import FixedWindows
from apache_beam.transforms.trigger import AfterWatermark, AfterProcessingTime, AccumulationMode

logger = logging.getLogger(__name__)

# Valid event types for CDR records
VALID_EVENT_TYPES = frozenset([
    'MOC', 'MTC', 'SMS_MO', 'SMS_MT', 'DATA', 'MMS_MO', 'MMS_MT',
    'GPRS', 'VOLTE', 'VOWIFI', 'USSD', 'CF', 'ROAMING',
])


class CDRParser(beam.DoFn):
    """Parse CDR records with format auto-detection (JSON, CSV, ASN.1 stub)."""

    def __init__(self):
        self.json_count = Metrics.counter(self.__class__, 'json_records')
        self.csv_count = Metrics.counter(self.__class__, 'csv_records')
        self.asn1_count = Metrics.counter(self.__class__, 'asn1_records')
        self.parse_errors = Metrics.counter(self.__class__, 'parse_errors')

    def _try_json(self, raw):
        """Attempt to parse as JSON."""
        record = json.loads(raw)
        if isinstance(record, dict):
            self.json_count.inc()
            return record
        return None

    def _try_csv(self, raw):
        """Attempt to parse as CSV with expected CDR header mapping."""
        CSV_FIELDS = [
            'cdr_id', 'subscriber_id', 'event_timestamp', 'event_type',
            'duration', 'data_volume_bytes', 'amount', 'called_number',
            'calling_number', 'cell_id', 'imsi', 'imei',
        ]
        reader = csv.reader(io.StringIO(raw))
        for row in reader:
            if len(row) >= 4:
                record = {}
                for i, field in enumerate(CSV_FIELDS):
                    if i < len(row):
                        record[field] = row[i].strip()
                # Convert numeric fields
                for num_field in ['duration', 'data_volume_bytes', 'amount']:
                    if num_field in record and record[num_field]:
                        try:
                            record[num_field] = float(record[num_field])
                        except (ValueError, TypeError):
                            pass
                self.csv_count.inc()
                return record
        return None

    def _try_asn1(self, raw):
        """Stub for ASN.1 BER/DER encoded CDR parsing.

        In production, this would use an ASN.1 library (e.g., pyasn1)
        to decode TAP3 or proprietary switch formats.
        """
        if raw.startswith(('\x30', '\xa0', '0x')):
            self.asn1_count.inc()
            return {
                '_asn1_raw': raw[:200],
                '_parse_note': 'ASN.1 parsing requires pyasn1 with proper schema definitions',
            }
        return None

    def process(self, raw):
        try:
            # Try JSON first (most common for streaming)
            try:
                record = self._try_json(raw)
                if record:
                    yield beam.pvalue.TaggedOutput('parsed', record)
                    return
            except (json.JSONDecodeError, ValueError):
                pass

            # Try CSV
            try:
                record = self._try_csv(raw)
                if record:
                    yield beam.pvalue.TaggedOutput('parsed', record)
                    return
            except Exception:
                pass

            # Try ASN.1 stub
            record = self._try_asn1(raw)
            if record:
                yield beam.pvalue.TaggedOutput('parsed', record)
                return

            # Nothing worked
            raise ValueError(f"Unable to detect CDR format for record: {raw[:100]}")

        except Exception as e:
            self.parse_errors.inc()
            yield beam.pvalue.TaggedOutput('errors', {
                'raw_record': str(raw)[:2000],
                'error': str(e),
                'error_type': 'PARSE_ERROR',
                'timestamp': datetime.utcnow().isoformat(),
                'pipeline': '{{ pipeline.name }}',
            })


class CDRValidator(beam.DoFn):
    """Validate CDR records for required fields and value ranges."""

    REQUIRED_FIELDS = ['cdr_id', 'subscriber_id', 'event_timestamp']

    def __init__(self):
        self.valid_count = Metrics.counter(self.__class__, 'valid_cdrs')
        self.invalid_count = Metrics.counter(self.__class__, 'invalid_cdrs')
        self.negative_duration = Metrics.counter(self.__class__, 'negative_duration')
        self.invalid_event_type = Metrics.counter(self.__class__, 'invalid_event_type')

    def process(self, record):
        errors = []

        # Check required fields
        missing = [f for f in self.REQUIRED_FIELDS if not record.get(f)]
        if missing:
            errors.append(f"Missing required fields: {', '.join(missing)}")

        # Validate duration (must be >= 0 if present)
        duration = record.get('duration')
        if duration is not None:
            try:
                dur_val = float(duration)
                if dur_val < 0:
                    self.negative_duration.inc()
                    errors.append(f"Negative duration: {dur_val}")
            except (ValueError, TypeError):
                errors.append(f"Invalid duration value: {duration}")

        # Validate amount (must be >= 0 if present)
        amount = record.get('amount')
        if amount is not None:
            try:
                amt_val = float(amount)
                if amt_val < 0:
                    errors.append(f"Negative amount: {amt_val}")
            except (ValueError, TypeError):
                errors.append(f"Invalid amount value: {amount}")

        # Validate event_type
        event_type = record.get('event_type')
        if event_type and event_type.upper() not in VALID_EVENT_TYPES:
            self.invalid_event_type.inc()
            errors.append(f"Invalid event_type: {event_type}")

        if errors:
            self.invalid_count.inc()
            yield beam.pvalue.TaggedOutput('invalid', {
                'record': record,
                'validation_errors': errors,
                'error_type': 'VALIDATION_ERROR',
                'timestamp': datetime.utcnow().isoformat(),
            })
        else:
            self.valid_count.inc()
            yield beam.pvalue.TaggedOutput('valid', record)


class CDREnricher(beam.DoFn):
    """Enrich CDR records with derived fields."""

    def __init__(self):
        self.enriched_count = Metrics.counter(self.__class__, 'enriched_cdrs')
        self.late_data_count = Metrics.counter(self.__class__, 'late_data_cdrs')

    def process(self, record):
        self.enriched_count.inc()

        # Add processing metadata
        record['_ingestion_timestamp'] = datetime.utcnow().isoformat()
        record['_source_pipeline'] = '{{ pipeline.name }}'
        record['_source_vendor'] = '{{ pipeline.source_vendor.value if pipeline.source_vendor else "unknown" }}'

        # Extract event_date from event_timestamp
        event_ts = record.get('event_timestamp', '')
        if event_ts:
            try:
                # Handle ISO format and other common timestamp formats
                for fmt in ['%Y-%m-%dT%H:%M:%S', '%Y-%m-%d %H:%M:%S', '%Y%m%d%H%M%S']:
                    try:
                        parsed_dt = datetime.strptime(str(event_ts)[:19], fmt)
                        record['event_date'] = parsed_dt.strftime('%Y-%m-%d')
                        record['event_hour'] = parsed_dt.hour

                        # Detect late data (event older than 24 hours)
                        age_hours = (datetime.utcnow() - parsed_dt).total_seconds() / 3600
                        if age_hours > 24:
                            record['_is_late_data'] = True
                            self.late_data_count.inc()
                        else:
                            record['_is_late_data'] = False
                        break
                    except ValueError:
                        continue
            except Exception:
                record['event_date'] = event_ts[:10] if len(event_ts) >= 10 else None

        # Normalize event_type to uppercase
        if 'event_type' in record and record['event_type']:
            record['event_type'] = record['event_type'].upper()

        # Determine network_type from event_type or cell_id
        event_type = record.get('event_type', '')
        if event_type in ('VOLTE', 'VOWIFI'):
            record['network_type'] = '4G_LTE'
        elif event_type == 'DATA' or event_type == 'GPRS':
            record['network_type'] = 'DATA'
        elif record.get('cell_id', '').startswith('5G'):
            record['network_type'] = '5G_NR'
        else:
            record['network_type'] = 'LEGACY'

        # Calculate discount stub (would look up from rating table in production)
        amount = record.get('amount')
        if amount is not None:
            try:
                amt_val = float(amount)
                # Apply a placeholder bundle discount of 0%
                record['discount_pct'] = 0.0
                record['net_amount'] = amt_val
            except (ValueError, TypeError):
                record['discount_pct'] = 0.0

        # Ensure numeric fields are properly typed
        for field in ['duration', 'data_volume_bytes', 'amount', 'net_amount']:
            if field in record and record[field] is not None:
                try:
                    record[field] = float(record[field])
                except (ValueError, TypeError):
                    pass

        yield record


class DuplicateDetector(beam.DoFn):
    """Detect and remove duplicate CDRs by cdr_id within a window."""

    def __init__(self):
        self.duplicates = Metrics.counter(self.__class__, 'duplicate_cdrs')
        self.unique = Metrics.counter(self.__class__, 'unique_cdrs')

    def process(self, element):
        cdr_id, records = element
        records_list = list(records)
        if len(records_list) > 1:
            self.duplicates.inc(len(records_list) - 1)
        self.unique.inc()
        # Keep the first occurrence (earliest ingestion timestamp)
        yield min(records_list, key=lambda r: r.get('_ingestion_timestamp', ''))


def run(argv=None):
    parser = argparse.ArgumentParser()
    parser.add_argument('--input_subscription', required=True, help='Pub/Sub subscription for CDR stream')
    parser.add_argument('--output_table', required=True, help='BigQuery output table (project:dataset.table)')
    parser.add_argument('--dead_letter_table', default=None, help='BigQuery dead letter table')
    parser.add_argument('--window_size', type=int, default=60, help='Window size in seconds')
    parser.add_argument('--late_data_window', type=int, default=3600, help='Allowed lateness in seconds')
    parser.add_argument('--temp_location', required=True, help='GCS temp location')
    known_args, pipeline_args = parser.parse_known_args(argv)

    options = PipelineOptions(pipeline_args)
    options.view_as(StandardOptions).streaming = True
    options.view_as(StandardOptions).runner = options.view_as(StandardOptions).runner or 'DataflowRunner'

    with beam.Pipeline(options=options) as p:
        # Read from Pub/Sub
        raw = (
            p
            | "ReadFromPubSub" >> beam.io.ReadFromPubSub(subscription=known_args.input_subscription)
            | "DecodeBytes" >> beam.Map(lambda x: x.decode('utf-8'))
        )

        # Parse with format detection
        parsed = (
            raw
            | "ParseCDR" >> beam.ParDo(CDRParser()).with_outputs('parsed', 'errors')
        )

        # Validate
        validated = (
            parsed.parsed
            | "ValidateCDR" >> beam.ParDo(CDRValidator()).with_outputs('valid', 'invalid')
        )

        # Enrich
        enriched = (
            validated.valid
            | "EnrichCDR" >> beam.ParDo(CDREnricher())
        )

        # Window and deduplicate
        deduped = (
            enriched
            | "WindowCDRs" >> beam.WindowInto(
                FixedWindows(known_args.window_size),
                allowed_lateness=known_args.late_data_window,
                trigger=AfterWatermark(
                    late=AfterProcessingTime(60),
                ),
                accumulation_mode=AccumulationMode.DISCARDING,
            )
            | "KeyByCDRId" >> beam.Map(lambda r: (r.get('cdr_id', ''), r))
            | "GroupByCDRId" >> beam.GroupByKey()
            | "Deduplicate" >> beam.ParDo(DuplicateDetector())
        )

        # Write to BigQuery
        deduped | "WriteToBigQuery" >> WriteToBigQuery(
            known_args.output_table,
            write_disposition=BigQueryDisposition.WRITE_APPEND,
            create_disposition=BigQueryDisposition.CREATE_NEVER,
            insert_retry_strategy='RETRY_ON_TRANSIENT_ERROR',
        )

        # Dead letter queue
        if known_args.dead_letter_table:
            (
                (parsed.errors, validated.invalid)
                | "FlattenErrors" >> beam.Flatten()
                | "WriteDeadLetters" >> WriteToBigQuery(
                    known_args.dead_letter_table,
                    write_disposition=BigQueryDisposition.WRITE_APPEND,
                    create_disposition=BigQueryDisposition.CREATE_IF_NEEDED,
                )
            )


if __name__ == "__main__":
    logging.basicConfig(level=logging.INFO)
    run()
