"""{{ pipeline.name }} - Revenue assurance pipeline.

Generated by TAA (Telco Analytics Accelerator).
Domain: {{ pipeline.telco_domain.value }}
"""

import apache_beam as beam
from apache_beam.options.pipeline_options import PipelineOptions


class RevenueAssuranceOptions(PipelineOptions):
    @classmethod
    def _add_argparse_args(cls, parser):
        parser.add_argument('--cdr_table', required=True, help='CDR BigQuery table')
        parser.add_argument('--billing_table', required=True, help='Billing BigQuery table')
        parser.add_argument('--output_table', required=True, help='Discrepancy output table')


def run():
    options = RevenueAssuranceOptions()

    with beam.Pipeline(options=options) as p:
        cdrs = (
            p
            | "ReadCDRs" >> beam.io.ReadFromBigQuery(table=options.cdr_table)
            | "KeyCDRs" >> beam.Map(lambda r: (r["subscriber_id"], r))
        )

        billing = (
            p
            | "ReadBilling" >> beam.io.ReadFromBigQuery(table=options.billing_table)
            | "KeyBilling" >> beam.Map(lambda r: (r["subscriber_id"], r))
        )

        (
            {"cdrs": cdrs, "billing": billing}
            | "CoGroupBySubscriber" >> beam.CoGroupByKey()
            | "DetectDiscrepancies" >> beam.FlatMap(detect_discrepancies)
            | "WriteDiscrepancies" >> beam.io.WriteToBigQuery(
                options.output_table,
                write_disposition=beam.io.BigQueryDisposition.WRITE_TRUNCATE,
                create_disposition=beam.io.BigQueryDisposition.CREATE_IF_NEEDED,
            )
        )


def detect_discrepancies(element):
    """Detect revenue discrepancies between CDRs and billing."""
    subscriber_id, groups = element
    cdrs = groups.get("cdrs", [])
    billing = groups.get("billing", [])

    cdr_total = sum(r.get("rated_amount", 0) for r in cdrs)
    bill_total = sum(r.get("total_amount", 0) for r in billing)

    if abs(cdr_total - bill_total) > 0.01:
        yield {
            "subscriber_id": subscriber_id,
            "cdr_total": cdr_total,
            "billing_total": bill_total,
            "discrepancy": cdr_total - bill_total,
        }


if __name__ == "__main__":
    run()
