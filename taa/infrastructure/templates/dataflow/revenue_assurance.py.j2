"""{{ pipeline.name }} - Revenue assurance pipeline.

Generated by TAA (Telco Analytics Accelerator).
Domain: {{ pipeline.telco_domain.value }}
{% if pipeline.source_vendor %}Vendor: {{ pipeline.source_vendor.value }}{% endif %}

CDR-to-billing reconciliation pipeline that:
  - Joins CDR rated amounts against billing system charges
  - Detects discrepancies with configurable tolerance thresholds
  - Identifies zero-rated CDRs that should have been charged
  - Flags unbilled usage (CDRs with no matching billing record)
  - Generates exception reports for revenue assurance review
"""

import argparse
import json
import logging
from datetime import datetime
from decimal import Decimal, ROUND_HALF_UP

import apache_beam as beam
from apache_beam.options.pipeline_options import PipelineOptions, StandardOptions
from apache_beam.io.gcp.bigquery import WriteToBigQuery, BigQueryDisposition
from apache_beam.metrics import Metrics

logger = logging.getLogger(__name__)

# Default tolerance thresholds
DEFAULT_AMOUNT_TOLERANCE = 0.01          # Absolute tolerance in currency units
DEFAULT_PERCENTAGE_TOLERANCE = 0.05      # 5% relative tolerance
DEFAULT_ZERO_RATE_THRESHOLD = 0.001      # Below this is considered zero-rated


class CDRKeyExtractor(beam.DoFn):
    """Extract join key from CDR records for reconciliation."""

    def __init__(self):
        self.cdr_count = Metrics.counter(self.__class__, 'cdrs_processed')
        self.cdr_keyed = Metrics.counter(self.__class__, 'cdrs_keyed')
        self.cdr_unkeyed = Metrics.counter(self.__class__, 'cdrs_unkeyed')

    def process(self, record):
        self.cdr_count.inc()

        subscriber_id = record.get('subscriber_id')
        if not subscriber_id:
            self.cdr_unkeyed.inc()
            yield beam.pvalue.TaggedOutput('unkeyed', {
                'record': record,
                'error': 'Missing subscriber_id',
                'source': 'CDR',
                'timestamp': datetime.utcnow().isoformat(),
            })
            return

        self.cdr_keyed.inc()
        # Key by subscriber_id and billing period
        billing_period = record.get('billing_period', record.get('event_date', '')[:7])
        key = f"{subscriber_id}|{billing_period}"
        yield beam.pvalue.TaggedOutput('keyed', (key, record))


class BillingKeyExtractor(beam.DoFn):
    """Extract join key from billing records for reconciliation."""

    def __init__(self):
        self.billing_count = Metrics.counter(self.__class__, 'billing_records_processed')

    def process(self, record):
        self.billing_count.inc()
        subscriber_id = record.get('subscriber_id')
        billing_period = record.get('billing_period', record.get('bill_cycle_date', '')[:7])
        key = f"{subscriber_id}|{billing_period}"
        yield (key, record)


class ZeroRatedCDRDetector(beam.DoFn):
    """Detect CDRs that have zero or near-zero rated amounts.

    Zero-rated CDRs are suspicious unless they match known free-of-charge
    scenarios (e.g., bundle inclusions, promotional offers, emergency calls).
    """

    EXEMPT_EVENT_TYPES = frozenset(['EMERGENCY', '911', '112', '999', 'TOLL_FREE'])

    def __init__(self, threshold=DEFAULT_ZERO_RATE_THRESHOLD):
        self.threshold = threshold
        self.zero_rated = Metrics.counter(self.__class__, 'zero_rated_cdrs')
        self.exempt_zero = Metrics.counter(self.__class__, 'exempt_zero_rated')
        self.normal_rated = Metrics.counter(self.__class__, 'normal_rated_cdrs')

    def process(self, record):
        rated_amount = record.get('rated_amount', record.get('amount', 0))
        try:
            rated_val = float(rated_amount) if rated_amount is not None else 0
        except (ValueError, TypeError):
            rated_val = 0

        if abs(rated_val) < self.threshold:
            event_type = str(record.get('event_type', '')).upper()
            if event_type in self.EXEMPT_EVENT_TYPES:
                self.exempt_zero.inc()
                return  # Skip exempt zero-rated CDRs

            # Non-exempt zero-rated CDR - flag as exception
            self.zero_rated.inc()
            yield {
                'exception_type': 'ZERO_RATED_CDR',
                'severity': 'MEDIUM',
                'subscriber_id': record.get('subscriber_id', ''),
                'cdr_id': record.get('cdr_id', ''),
                'event_type': record.get('event_type', ''),
                'event_date': record.get('event_date', ''),
                'duration': record.get('duration', 0),
                'data_volume_bytes': record.get('data_volume_bytes', 0),
                'rated_amount': rated_val,
                'description': (
                    f"CDR {record.get('cdr_id', 'N/A')} has zero/near-zero rated amount "
                    f"({rated_val}) for event type {record.get('event_type', 'N/A')} "
                    f"with duration {record.get('duration', 0)}"
                ),
                'detection_timestamp': datetime.utcnow().isoformat(),
                '_source_pipeline': '{{ pipeline.name }}',
            }
        else:
            self.normal_rated.inc()


class ReconciliationEngine(beam.DoFn):
    """Reconcile CDR rated amounts against billing charges.

    Performs subscriber-level and period-level matching, detecting:
    - Amount discrepancies exceeding tolerance
    - Unbilled usage (CDRs with no billing match)
    - Overbilling (billing without corresponding CDRs)
    """

    def __init__(self, amount_tolerance=DEFAULT_AMOUNT_TOLERANCE,
                 percentage_tolerance=DEFAULT_PERCENTAGE_TOLERANCE):
        self.amount_tolerance = amount_tolerance
        self.percentage_tolerance = percentage_tolerance
        self.matched = Metrics.counter(self.__class__, 'reconciled_matched')
        self.discrepancies = Metrics.counter(self.__class__, 'reconciled_discrepancies')
        self.unbilled = Metrics.counter(self.__class__, 'unbilled_usage')
        self.overbilled = Metrics.counter(self.__class__, 'overbilled')

    def process(self, element):
        key, groups = element
        cdrs = list(groups.get('cdrs', []))
        billing = list(groups.get('billing', []))

        parts = key.split('|', 1)
        subscriber_id = parts[0] if parts else 'UNKNOWN'
        billing_period = parts[1] if len(parts) > 1 else 'UNKNOWN'

        # Calculate CDR total
        cdr_total = Decimal('0')
        cdr_count = len(cdrs)
        cdr_by_type = {}
        for cdr in cdrs:
            amount = cdr.get('rated_amount', cdr.get('amount', 0))
            try:
                amt = Decimal(str(amount)) if amount is not None else Decimal('0')
            except Exception:
                amt = Decimal('0')
            cdr_total += amt

            event_type = cdr.get('event_type', 'UNKNOWN')
            if event_type not in cdr_by_type:
                cdr_by_type[event_type] = {'count': 0, 'amount': Decimal('0')}
            cdr_by_type[event_type]['count'] += 1
            cdr_by_type[event_type]['amount'] += amt

        # Calculate billing total
        bill_total = Decimal('0')
        bill_count = len(billing)
        for bill in billing:
            amount = bill.get('total_amount', bill.get('billed_amount', 0))
            try:
                amt = Decimal(str(amount)) if amount is not None else Decimal('0')
            except Exception:
                amt = Decimal('0')
            bill_total += amt

        # Determine discrepancy
        discrepancy = cdr_total - bill_total
        abs_discrepancy = abs(discrepancy)

        # Calculate percentage discrepancy (relative to the larger amount)
        max_amount = max(abs(cdr_total), abs(bill_total))
        pct_discrepancy = (
            float(abs_discrepancy / max_amount) if max_amount > 0 else 0.0
        )

        # Unbilled usage: CDRs exist but no billing records
        if cdr_count > 0 and bill_count == 0:
            self.unbilled.inc()
            yield {
                'exception_type': 'UNBILLED_USAGE',
                'severity': 'HIGH',
                'subscriber_id': subscriber_id,
                'billing_period': billing_period,
                'cdr_count': cdr_count,
                'cdr_total': float(cdr_total),
                'billing_count': 0,
                'billing_total': 0.0,
                'discrepancy_amount': float(cdr_total),
                'discrepancy_pct': 1.0,
                'cdr_type_breakdown': json.dumps(
                    {k: {'count': v['count'], 'amount': float(v['amount'])}
                     for k, v in cdr_by_type.items()}
                ),
                'description': (
                    f"Subscriber {subscriber_id} has {cdr_count} CDRs "
                    f"totaling {float(cdr_total):.2f} with no billing records "
                    f"for period {billing_period}"
                ),
                'detection_timestamp': datetime.utcnow().isoformat(),
                '_source_pipeline': '{{ pipeline.name }}',
            }
            return

        # Overbilling: billing exists but no CDRs
        if bill_count > 0 and cdr_count == 0:
            self.overbilled.inc()
            yield {
                'exception_type': 'OVERBILLING',
                'severity': 'HIGH',
                'subscriber_id': subscriber_id,
                'billing_period': billing_period,
                'cdr_count': 0,
                'cdr_total': 0.0,
                'billing_count': bill_count,
                'billing_total': float(bill_total),
                'discrepancy_amount': float(-bill_total),
                'discrepancy_pct': 1.0,
                'description': (
                    f"Subscriber {subscriber_id} has {bill_count} billing records "
                    f"totaling {float(bill_total):.2f} with no corresponding CDRs "
                    f"for period {billing_period}"
                ),
                'detection_timestamp': datetime.utcnow().isoformat(),
                '_source_pipeline': '{{ pipeline.name }}',
            }
            return

        # Amount discrepancy check
        exceeds_absolute = abs_discrepancy > Decimal(str(self.amount_tolerance))
        exceeds_percentage = pct_discrepancy > self.percentage_tolerance

        if exceeds_absolute and exceeds_percentage:
            self.discrepancies.inc()
            severity = 'CRITICAL' if pct_discrepancy > 0.20 else 'HIGH' if pct_discrepancy > 0.10 else 'MEDIUM'
            yield {
                'exception_type': 'AMOUNT_DISCREPANCY',
                'severity': severity,
                'subscriber_id': subscriber_id,
                'billing_period': billing_period,
                'cdr_count': cdr_count,
                'cdr_total': float(cdr_total),
                'billing_count': bill_count,
                'billing_total': float(bill_total),
                'discrepancy_amount': float(discrepancy),
                'discrepancy_pct': round(pct_discrepancy, 4),
                'cdr_type_breakdown': json.dumps(
                    {k: {'count': v['count'], 'amount': float(v['amount'])}
                     for k, v in cdr_by_type.items()}
                ),
                'description': (
                    f"Subscriber {subscriber_id}: CDR total {float(cdr_total):.2f} vs "
                    f"billing total {float(bill_total):.2f} "
                    f"(diff: {float(discrepancy):.2f}, {pct_discrepancy:.1%})"
                ),
                'detection_timestamp': datetime.utcnow().isoformat(),
                '_source_pipeline': '{{ pipeline.name }}',
            }
        else:
            self.matched.inc()


class ExceptionReportBuilder(beam.DoFn):
    """Enrich exception records with additional context for reporting."""

    def __init__(self):
        self.exceptions_processed = Metrics.counter(self.__class__, 'exceptions_processed')

    def process(self, record):
        self.exceptions_processed.inc()

        # Add report metadata
        record['report_date'] = datetime.utcnow().strftime('%Y-%m-%d')
        record['report_id'] = (
            f"{record.get('exception_type', 'UNKNOWN')}_"
            f"{record.get('subscriber_id', 'UNKNOWN')}_"
            f"{record.get('billing_period', 'UNKNOWN')}"
        )

        # Assign priority for triage
        severity = record.get('severity', 'LOW')
        discrepancy_amount = abs(record.get('discrepancy_amount', 0))
        if severity == 'CRITICAL' or discrepancy_amount > 10000:
            record['priority'] = 1
        elif severity == 'HIGH' or discrepancy_amount > 1000:
            record['priority'] = 2
        elif severity == 'MEDIUM' or discrepancy_amount > 100:
            record['priority'] = 3
        else:
            record['priority'] = 4

        # Assign to review queue
        exception_type = record.get('exception_type', '')
        if exception_type in ('UNBILLED_USAGE', 'OVERBILLING'):
            record['review_queue'] = 'BILLING_OPS'
        elif exception_type == 'ZERO_RATED_CDR':
            record['review_queue'] = 'RATING_TEAM'
        else:
            record['review_queue'] = 'REVENUE_ASSURANCE'

        record['status'] = 'OPEN'

        yield record


def run(argv=None):
    parser = argparse.ArgumentParser()
    parser.add_argument('--cdr_table', required=True,
                        help='BigQuery CDR table (project:dataset.table)')
    parser.add_argument('--billing_table', required=True,
                        help='BigQuery billing table (project:dataset.table)')
    parser.add_argument('--output_table', required=True,
                        help='BigQuery exception output table (project:dataset.table)')
    parser.add_argument('--zero_rated_table', default=None,
                        help='BigQuery table for zero-rated CDR exceptions')
    parser.add_argument('--summary_table', default=None,
                        help='BigQuery table for reconciliation summary')
    parser.add_argument('--amount_tolerance', type=float, default=DEFAULT_AMOUNT_TOLERANCE,
                        help=f'Absolute amount tolerance (default: {DEFAULT_AMOUNT_TOLERANCE})')
    parser.add_argument('--percentage_tolerance', type=float, default=DEFAULT_PERCENTAGE_TOLERANCE,
                        help=f'Percentage tolerance (default: {DEFAULT_PERCENTAGE_TOLERANCE})')
    parser.add_argument('--zero_rate_threshold', type=float, default=DEFAULT_ZERO_RATE_THRESHOLD,
                        help=f'Zero-rate detection threshold (default: {DEFAULT_ZERO_RATE_THRESHOLD})')
    parser.add_argument('--temp_location', required=True, help='GCS temp location')
    known_args, pipeline_args = parser.parse_known_args(argv)

    options = PipelineOptions(pipeline_args)
    options.view_as(StandardOptions).runner = options.view_as(StandardOptions).runner or 'DataflowRunner'

    with beam.Pipeline(options=options) as p:
        # Read CDRs
        cdr_results = (
            p
            | "ReadCDRs" >> beam.io.ReadFromBigQuery(table=known_args.cdr_table)
            | "ExtractCDRKeys" >> beam.ParDo(CDRKeyExtractor()).with_outputs('keyed', 'unkeyed')
        )

        keyed_cdrs = cdr_results.keyed

        # Read billing records
        keyed_billing = (
            p
            | "ReadBilling" >> beam.io.ReadFromBigQuery(table=known_args.billing_table)
            | "ExtractBillingKeys" >> beam.ParDo(BillingKeyExtractor())
        )

        # Reconcile CDRs against billing
        reconciliation_exceptions = (
            {'cdrs': keyed_cdrs, 'billing': keyed_billing}
            | "CoGroupBySubscriber" >> beam.CoGroupByKey()
            | "Reconcile" >> beam.ParDo(
                ReconciliationEngine(
                    amount_tolerance=known_args.amount_tolerance,
                    percentage_tolerance=known_args.percentage_tolerance,
                )
            )
        )

        # Detect zero-rated CDRs
        zero_rated_exceptions = (
            p
            | "ReadCDRsForZeroRate" >> beam.io.ReadFromBigQuery(
                table=known_args.cdr_table,
                # In production, add a query filter for the analysis window
            )
            | "DetectZeroRated" >> beam.ParDo(
                ZeroRatedCDRDetector(threshold=known_args.zero_rate_threshold)
            )
        )

        # Merge all exceptions and build reports
        all_exceptions = (
            (reconciliation_exceptions, zero_rated_exceptions)
            | "FlattenExceptions" >> beam.Flatten()
            | "BuildExceptionReport" >> beam.ParDo(ExceptionReportBuilder())
        )

        # Write exception reports
        all_exceptions | "WriteExceptions" >> WriteToBigQuery(
            known_args.output_table,
            write_disposition=BigQueryDisposition.WRITE_TRUNCATE,
            create_disposition=BigQueryDisposition.CREATE_IF_NEEDED,
            insert_retry_strategy='RETRY_ON_TRANSIENT_ERROR',
        )

        # Optionally write zero-rated CDRs to a separate table
        if known_args.zero_rated_table:
            (
                zero_rated_exceptions
                | "WriteZeroRated" >> WriteToBigQuery(
                    known_args.zero_rated_table,
                    write_disposition=BigQueryDisposition.WRITE_APPEND,
                    create_disposition=BigQueryDisposition.CREATE_IF_NEEDED,
                )
            )

        # Generate reconciliation summary
        if known_args.summary_table:
            (
                all_exceptions
                | "KeyByType" >> beam.Map(lambda r: (r.get('exception_type', 'UNKNOWN'), r))
                | "GroupByType" >> beam.GroupByKey()
                | "Summarize" >> beam.Map(lambda kv: {
                    'exception_type': kv[0],
                    'exception_count': len(list(kv[1])),
                    'total_discrepancy': sum(
                        abs(r.get('discrepancy_amount', 0)) for r in kv[1]
                    ),
                    'report_date': datetime.utcnow().strftime('%Y-%m-%d'),
                    '_source_pipeline': '{{ pipeline.name }}',
                })
                | "WriteSummary" >> WriteToBigQuery(
                    known_args.summary_table,
                    write_disposition=BigQueryDisposition.WRITE_TRUNCATE,
                    create_disposition=BigQueryDisposition.CREATE_IF_NEEDED,
                )
            )

        # Write unkeyed CDRs (missing subscriber_id) as data quality issues
        (
            cdr_results.unkeyed
            | "WriteUnkeyedCDRs" >> WriteToBigQuery(
                known_args.output_table,
                write_disposition=BigQueryDisposition.WRITE_APPEND,
                create_disposition=BigQueryDisposition.CREATE_IF_NEEDED,
            )
        )


if __name__ == "__main__":
    logging.basicConfig(level=logging.INFO)
    run()
