Generated by TAA (Telco Analytics Accelerator).
Domain: {{ pipeline.telco_domain.value }}
"""

import apache_beam as beam
from apache_beam.options.pipeline_options import PipelineOptions


class CDCOptions(PipelineOptions):
    @classmethod
    def _add_argparse_args(cls, parser):
        parser.add_argument('--input_subscription', required=True, help='Pub/Sub subscription for CDC events')
        parser.add_argument('--output_table', required=True, help='BigQuery output table')


def run():
    options = CDCOptions()

    with beam.Pipeline(options=options) as p:
        (
            p
            | "ReadCDCEvents" >> beam.io.ReadFromPubSub(subscription=options.input_subscription)
            | "DecodeBytes" >> beam.Map(lambda x: x.decode("utf-8"))
            | "ParseEvent" >> beam.Map(parse_cdc_event)
            | "ApplyChanges" >> beam.Map(apply_change)
            | "WriteToBigQuery" >> beam.io.WriteToBigQuery(
                options.output_table,
                write_disposition=beam.io.BigQueryDisposition.WRITE_APPEND,
                create_disposition=beam.io.BigQueryDisposition.CREATE_NEVER,
            )
        )


def parse_cdc_event(raw: str) -> dict:
    """Parse CDC event."""
    import json
    return json.loads(raw)


def apply_change(event: dict) -> dict:
    """Apply CDC change logic."""
    event["_cdc_operation"] = event.get("op", "INSERT")
    return event


if __name__ == "__main__":
    run()
