"""{{ pipeline.name }} - Change Data Capture pipeline.

Generated by TAA (Telco Analytics Accelerator).
Domain: {{ pipeline.telco_domain.value }}
{% if pipeline.source_vendor %}Vendor: {{ pipeline.source_vendor.value }}{% endif %}

Handles INSERT, UPDATE, and DELETE operations from source CDC streams.
Uses BigQuery MERGE for upsert semantics and supports schema evolution.
"""

import argparse
import json
import logging
from datetime import datetime

import apache_beam as beam
from apache_beam.options.pipeline_options import PipelineOptions, StandardOptions
from apache_beam.io.gcp.bigquery import WriteToBigQuery, BigQueryDisposition
from apache_beam.metrics import Metrics
from apache_beam.transforms.window import FixedWindows

logger = logging.getLogger(__name__)

# Supported CDC operation types (normalized)
CDC_OPERATIONS = frozenset(['INSERT', 'UPDATE', 'DELETE', 'UPSERT', 'SNAPSHOT'])

# Common CDC source format field mappings
CDC_OP_FIELD_MAP = {
    # Debezium
    'op': {'c': 'INSERT', 'u': 'UPDATE', 'd': 'DELETE', 'r': 'SNAPSHOT'},
    # Maxwell
    'type': {'insert': 'INSERT', 'update': 'UPDATE', 'delete': 'DELETE'},
    # Custom / generic
    'operation': {},
    '_cdc_operation': {},
}


class CDCEventParser(beam.DoFn):
    """Parse CDC events and normalize operation types from various source formats."""

    def __init__(self):
        self.parse_success = Metrics.counter(self.__class__, 'parse_success')
        self.parse_errors = Metrics.counter(self.__class__, 'parse_errors')
        self.inserts = Metrics.counter(self.__class__, 'cdc_inserts')
        self.updates = Metrics.counter(self.__class__, 'cdc_updates')
        self.deletes = Metrics.counter(self.__class__, 'cdc_deletes')

    def _detect_operation(self, event):
        """Detect and normalize the CDC operation type."""
        for field, mapping in CDC_OP_FIELD_MAP.items():
            if field in event:
                raw_op = str(event[field]).strip()
                if mapping:
                    normalized = mapping.get(raw_op, mapping.get(raw_op.lower()))
                    if normalized:
                        return normalized
                # Try direct match
                if raw_op.upper() in CDC_OPERATIONS:
                    return raw_op.upper()
        return 'INSERT'  # Default to INSERT for unrecognized operations

    def _extract_payload(self, event):
        """Extract the data payload from various CDC envelope formats."""
        # Debezium format: payload.after / payload.before
        if 'payload' in event and isinstance(event['payload'], dict):
            payload = event['payload']
            after = payload.get('after')
            before = payload.get('before')
            source_meta = payload.get('source', {})
            return after or before, before, source_meta

        # Flat format: data is the event itself
        after = event.get('after', event.get('data', event))
        before = event.get('before')
        return after, before, {}

    def process(self, raw):
        try:
            event = json.loads(raw)
            self.parse_success.inc()

            operation = self._detect_operation(event)
            after, before, source_meta = self._extract_payload(event)

            # Count by operation type
            if operation == 'INSERT':
                self.inserts.inc()
            elif operation == 'UPDATE':
                self.updates.inc()
            elif operation == 'DELETE':
                self.deletes.inc()

            # Build normalized CDC record
            cdc_record = {
                '_cdc_operation': operation,
                '_cdc_timestamp': event.get('ts_ms', event.get('timestamp', datetime.utcnow().isoformat())),
                '_cdc_source_table': source_meta.get('table', event.get('table', '')),
                '_cdc_source_db': source_meta.get('db', event.get('database', '')),
                '_cdc_lsn': str(event.get('lsn', event.get('position', ''))),
                '_processing_timestamp': datetime.utcnow().isoformat(),
                '_source_pipeline': '{{ pipeline.name }}',
            }

            if after and isinstance(after, dict):
                cdc_record.update(after)
            if before and isinstance(before, dict):
                cdc_record['_before_image'] = json.dumps(before)

            yield beam.pvalue.TaggedOutput('parsed', cdc_record)

        except (json.JSONDecodeError, ValueError, TypeError) as e:
            self.parse_errors.inc()
            yield beam.pvalue.TaggedOutput('errors', {
                'raw_record': str(raw)[:2000],
                'error': str(e),
                'error_type': 'CDC_PARSE_ERROR',
                'timestamp': datetime.utcnow().isoformat(),
                'pipeline': '{{ pipeline.name }}',
            })


class CDCValidator(beam.DoFn):
    """Validate CDC events have required key fields."""

    PRIMARY_KEY_FIELDS = {{ pipeline.primary_keys | default(["'id'"]) }}

    def __init__(self):
        self.valid_count = Metrics.counter(self.__class__, 'valid_events')
        self.invalid_count = Metrics.counter(self.__class__, 'invalid_events')

    def process(self, record):
        operation = record.get('_cdc_operation', 'INSERT')
        errors = []

        # For DELETE, we only need the primary key
        if operation == 'DELETE':
            missing_keys = [k for k in self.PRIMARY_KEY_FIELDS if not record.get(k)]
            if missing_keys:
                errors.append(f"DELETE missing primary key fields: {', '.join(missing_keys)}")
        else:
            # For INSERT/UPDATE, check primary key fields exist
            missing_keys = [k for k in self.PRIMARY_KEY_FIELDS if not record.get(k)]
            if missing_keys:
                errors.append(f"{operation} missing primary key fields: {', '.join(missing_keys)}")

        if errors:
            self.invalid_count.inc()
            yield beam.pvalue.TaggedOutput('invalid', {
                'record': record,
                'validation_errors': errors,
                'error_type': 'CDC_VALIDATION_ERROR',
                'timestamp': datetime.utcnow().isoformat(),
            })
        else:
            self.valid_count.inc()
            yield beam.pvalue.TaggedOutput('valid', record)


class CDCOrderResolver(beam.DoFn):
    """Resolve ordering for CDC events with the same key in a window.

    When multiple CDC events arrive for the same primary key within a window,
    keep only the latest event based on CDC timestamp.
    """

    def __init__(self):
        self.resolved = Metrics.counter(self.__class__, 'order_conflicts_resolved')

    def process(self, element):
        key, events = element
        events_list = list(events)
        if len(events_list) > 1:
            self.resolved.inc(len(events_list) - 1)
        # Keep the latest event by CDC timestamp
        latest = max(events_list, key=lambda r: r.get('_cdc_timestamp', ''))
        yield latest


class SchemaEvolutionHandler(beam.DoFn):
    """Handle schema evolution by detecting new fields and applying defaults.

    In production, this would integrate with a schema registry (e.g., Confluent
    Schema Registry or GCP Data Catalog) for proper schema versioning.
    """

    # Known columns and their default values for backward compatibility
    KNOWN_DEFAULTS = {
        'is_active': True,
        'updated_at': None,
        'version': 1,
    }

    def __init__(self):
        self.new_fields_detected = Metrics.counter(self.__class__, 'new_fields_detected')

    def process(self, record):
        # Apply defaults for known fields that are missing
        for field, default in self.KNOWN_DEFAULTS.items():
            if field not in record:
                record[field] = default

        # Tag records that have fields not in the known schema
        # This allows downstream monitoring to detect schema drift
        known_fields = set(self.KNOWN_DEFAULTS.keys())
        known_fields.update(['_cdc_operation', '_cdc_timestamp', '_cdc_source_table',
                             '_cdc_source_db', '_cdc_lsn', '_processing_timestamp',
                             '_source_pipeline', '_before_image'])
        data_fields = {k for k in record.keys() if not k.startswith('_')}
        new_fields = data_fields - known_fields
        if new_fields:
            self.new_fields_detected.inc(len(new_fields))
            record['_new_fields'] = list(new_fields)

        yield record


class PrepareMergeStatement(beam.DoFn):
    """Prepare records for BigQuery MERGE (upsert) operations.

    Separates records into upserts (INSERT/UPDATE) and deletes,
    adding metadata needed for the MERGE DML.
    """

    def process(self, record):
        operation = record.get('_cdc_operation', 'INSERT')

        if operation == 'DELETE':
            # For deletes, we soft-delete by setting _is_deleted flag
            record['_is_deleted'] = True
            record['_deleted_at'] = datetime.utcnow().isoformat()
            yield beam.pvalue.TaggedOutput('upserts', record)
        else:
            record['_is_deleted'] = False
            record['_deleted_at'] = None
            yield beam.pvalue.TaggedOutput('upserts', record)


def run(argv=None):
    parser = argparse.ArgumentParser()
    parser.add_argument('--input_subscription', required=True,
                        help='Pub/Sub subscription for CDC events')
    parser.add_argument('--output_table', required=True,
                        help='BigQuery output table (project:dataset.table)')
    parser.add_argument('--dead_letter_table', default=None,
                        help='BigQuery dead letter table')
    parser.add_argument('--staging_dataset', default=None,
                        help='BigQuery staging dataset for MERGE operations')
    parser.add_argument('--window_size', type=int, default=30,
                        help='Window size in seconds for batching CDC events')
    parser.add_argument('--temp_location', required=True, help='GCS temp location')
    known_args, pipeline_args = parser.parse_known_args(argv)

    options = PipelineOptions(pipeline_args)
    options.view_as(StandardOptions).streaming = True
    options.view_as(StandardOptions).runner = options.view_as(StandardOptions).runner or 'DataflowRunner'

    with beam.Pipeline(options=options) as p:
        # Read CDC events from Pub/Sub
        raw = (
            p
            | "ReadCDCEvents" >> beam.io.ReadFromPubSub(subscription=known_args.input_subscription)
            | "DecodeBytes" >> beam.Map(lambda x: x.decode('utf-8'))
        )

        # Parse and normalize
        parsed = (
            raw
            | "ParseCDCEvent" >> beam.ParDo(CDCEventParser()).with_outputs('parsed', 'errors')
        )

        # Validate
        validated = (
            parsed.parsed
            | "ValidateCDC" >> beam.ParDo(CDCValidator()).with_outputs('valid', 'invalid')
        )

        # Window, resolve ordering, handle schema evolution
        processed = (
            validated.valid
            | "WindowCDC" >> beam.WindowInto(FixedWindows(known_args.window_size))
            | "KeyByPK" >> beam.Map(
                lambda r: (
                    '_'.join(str(r.get(k, '')) for k in {{ pipeline.primary_keys | default(["'id'"]) }}),
                    r,
                )
            )
            | "GroupByPK" >> beam.GroupByKey()
            | "ResolveOrder" >> beam.ParDo(CDCOrderResolver())
            | "HandleSchemaEvolution" >> beam.ParDo(SchemaEvolutionHandler())
        )

        # Prepare for MERGE
        merge_ready = (
            processed
            | "PrepareMerge" >> beam.ParDo(PrepareMergeStatement()).with_outputs('upserts')
        )

        # Write upserts to BigQuery
        # Using WRITE_APPEND to a staging table; a scheduled query or
        # Cloud Function triggers the actual MERGE into the target table
        merge_ready.upserts | "WriteUpserts" >> WriteToBigQuery(
            known_args.output_table,
            write_disposition=BigQueryDisposition.WRITE_APPEND,
            create_disposition=BigQueryDisposition.CREATE_NEVER,
            insert_retry_strategy='RETRY_ON_TRANSIENT_ERROR',
            additional_bq_parameters={
                'timePartitioning': {
                    'type': 'DAY',
                    'field': '_processing_timestamp',
                },
            },
        )

        # Dead letter queue
        if known_args.dead_letter_table:
            (
                (parsed.errors, validated.invalid)
                | "FlattenErrors" >> beam.Flatten()
                | "WriteDeadLetters" >> WriteToBigQuery(
                    known_args.dead_letter_table,
                    write_disposition=BigQueryDisposition.WRITE_APPEND,
                    create_disposition=BigQueryDisposition.CREATE_IF_NEEDED,
                )
            )


if __name__ == "__main__":
    logging.basicConfig(level=logging.INFO)
    run()
