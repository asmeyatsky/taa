"""{{ pipeline.name }} - TAP/RAP processing pipeline.

Generated by TAA (Telco Analytics Accelerator).
Domain: {{ pipeline.telco_domain.value }}
"""

import apache_beam as beam
from apache_beam.options.pipeline_options import PipelineOptions


class TAPRAPOptions(PipelineOptions):
    @classmethod
    def _add_argparse_args(cls, parser):
        parser.add_argument('--input_path', required=True, help='GCS path to TAP files')
        parser.add_argument('--output_table', required=True, help='BigQuery output table')
        parser.add_argument('--partner_config', required=True, help='Partner configuration path')


def run():
    options = TAPRAPOptions()

    with beam.Pipeline(options=options) as p:
        (
            p
            | "ReadTAPFiles" >> beam.io.ReadFromText(options.input_path)
            | "ParseTAPRecords" >> beam.Map(parse_tap_record)
            | "ValidateTAP" >> beam.Filter(validate_tap)
            | "CalculateSettlement" >> beam.Map(calculate_settlement)
            | "WriteToBigQuery" >> beam.io.WriteToBigQuery(
                options.output_table,
                write_disposition=beam.io.BigQueryDisposition.WRITE_APPEND,
                create_disposition=beam.io.BigQueryDisposition.CREATE_NEVER,
            )
        )


def parse_tap_record(line: str) -> dict:
    """Parse TAP/RAP record."""
    import json
    return json.loads(line)


def validate_tap(record: dict) -> bool:
    """Validate TAP record."""
    return bool(record.get("event_id"))


def calculate_settlement(record: dict) -> dict:
    """Calculate settlement amounts."""
    record["settlement_amount"] = record.get("tap_amount", 0)
    return record


if __name__ == "__main__":
    run()
