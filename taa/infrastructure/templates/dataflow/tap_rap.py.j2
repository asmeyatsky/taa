"""{{ pipeline.name }} - TAP/RAP processing pipeline.

Generated by TAA (Telco Analytics Accelerator).
Domain: {{ pipeline.telco_domain.value }}
{% if pipeline.source_vendor %}Vendor: {{ pipeline.source_vendor.value }}{% endif %}

Processes TAP3 (Transferred Account Procedure) roaming files:
  - TAP3 record parsing (ASN.1 stub with JSON fallback)
  - IOT (Inter-Operator Tariff) rate application
  - Currency conversion to settlement currency
  - Settlement amount calculation
  - RAP (Returned Account Procedure) error file generation
"""

import argparse
import json
import logging
from datetime import datetime
from decimal import Decimal, ROUND_HALF_UP, InvalidOperation

import apache_beam as beam
from apache_beam.options.pipeline_options import PipelineOptions, StandardOptions
from apache_beam.io.gcp.bigquery import WriteToBigQuery, BigQueryDisposition
from apache_beam.metrics import Metrics

logger = logging.getLogger(__name__)

# TAP3 record type identifiers
TAP_RECORD_TYPES = frozenset([
    'MOC', 'MTC', 'GPRS', 'SMS_MO', 'SMS_MT', 'DATA',
    'CONTENT', 'MESSAGING', 'SUPPLEMENTARY',
])

# Default IOT rates by service type (placeholder - production would load from config)
DEFAULT_IOT_RATES = {
    'MOC': {'per_second': Decimal('0.0035'), 'setup_fee': Decimal('0.00')},
    'MTC': {'per_second': Decimal('0.0020'), 'setup_fee': Decimal('0.00')},
    'SMS_MO': {'per_event': Decimal('0.04')},
    'SMS_MT': {'per_event': Decimal('0.01')},
    'GPRS': {'per_kb': Decimal('0.0001')},
    'DATA': {'per_kb': Decimal('0.0001')},
}

# Sample exchange rates (production would call an FX rate API or side input)
DEFAULT_EXCHANGE_RATES = {
    'USD': Decimal('1.0'),
    'EUR': Decimal('1.08'),
    'GBP': Decimal('1.26'),
    'SDR': Decimal('1.33'),  # IMF Special Drawing Rights (TAP standard)
    'CHF': Decimal('1.12'),
    'JPY': Decimal('0.0067'),
}


class TAPRecordParser(beam.DoFn):
    """Parse TAP3 records from ASN.1 (stub) or JSON format.

    In production, ASN.1 BER decoding would be handled via pyasn1 with the
    GSM TAP3 ASN.1 module definitions (3GPP TS 32.297 / TD.57).
    """

    def __init__(self):
        self.json_parsed = Metrics.counter(self.__class__, 'json_records')
        self.asn1_detected = Metrics.counter(self.__class__, 'asn1_records')
        self.parse_errors = Metrics.counter(self.__class__, 'parse_errors')

    def _parse_asn1_stub(self, raw):
        """Stub for ASN.1 BER/DER decoding of TAP3 files.

        Production implementation would:
        1. Load TAP3 ASN.1 schema (TD.57 / TAP3.12)
        2. Decode BER-encoded transfer batch
        3. Extract individual call event details
        4. Map ASN.1 fields to canonical record format
        """
        if isinstance(raw, bytes) or (isinstance(raw, str) and raw.startswith(('\x30', '\xa0'))):
            self.asn1_detected.inc()
            return None  # Return None to signal ASN.1 not decoded
        return None

    def process(self, line):
        try:
            # Try ASN.1 detection first
            asn1_result = self._parse_asn1_stub(line)
            if asn1_result is not None:
                yield beam.pvalue.TaggedOutput('parsed', asn1_result)
                return

            # Parse as JSON (primary format for the template)
            record = json.loads(line)
            self.json_parsed.inc()

            # Ensure required TAP fields
            if 'record_type' not in record:
                record['record_type'] = 'MOC'  # Default

            # Normalize record_type
            record['record_type'] = record['record_type'].upper()

            yield beam.pvalue.TaggedOutput('parsed', record)

        except (json.JSONDecodeError, ValueError, TypeError) as e:
            self.parse_errors.inc()
            yield beam.pvalue.TaggedOutput('errors', {
                'raw_record': str(line)[:2000],
                'error': str(e),
                'error_type': 'TAP_PARSE_ERROR',
                'error_code': 'RAP_50',  # TAP decode failure
                'timestamp': datetime.utcnow().isoformat(),
                'pipeline': '{{ pipeline.name }}',
            })


class TAPValidator(beam.DoFn):
    """Validate TAP3 records for completeness and integrity.

    Checks conform to GSMA TAP3 validation requirements and generate
    RAP error codes for non-conforming records.
    """

    REQUIRED_FIELDS = ['record_type', 'imsi', 'call_timestamp']
    REQUIRED_FOR_MOC_MTC = ['duration', 'called_number']
    REQUIRED_FOR_DATA = ['data_volume_bytes']

    def __init__(self):
        self.valid_count = Metrics.counter(self.__class__, 'valid_tap_records')
        self.invalid_count = Metrics.counter(self.__class__, 'invalid_tap_records')

    def process(self, record):
        errors = []
        rap_errors = []

        # Check mandatory fields
        missing = [f for f in self.REQUIRED_FIELDS if not record.get(f)]
        if missing:
            errors.append(f"Missing required fields: {', '.join(missing)}")
            rap_errors.append({'code': 'RAP_20', 'detail': f"Missing: {', '.join(missing)}"})

        # Record-type-specific validation
        record_type = record.get('record_type', '').upper()
        if record_type in ('MOC', 'MTC'):
            missing_voice = [f for f in self.REQUIRED_FOR_MOC_MTC if not record.get(f)]
            if missing_voice:
                errors.append(f"Voice record missing: {', '.join(missing_voice)}")
                rap_errors.append({'code': 'RAP_21', 'detail': f"Missing: {', '.join(missing_voice)}"})
            # Duration must be positive
            duration = record.get('duration')
            if duration is not None:
                try:
                    if float(duration) < 0:
                        errors.append("Negative duration")
                        rap_errors.append({'code': 'RAP_30', 'detail': f"Negative duration: {duration}"})
                except (ValueError, TypeError):
                    errors.append(f"Invalid duration: {duration}")
                    rap_errors.append({'code': 'RAP_31', 'detail': f"Non-numeric duration: {duration}"})

        elif record_type in ('GPRS', 'DATA'):
            missing_data = [f for f in self.REQUIRED_FOR_DATA if not record.get(f)]
            if missing_data:
                errors.append(f"Data record missing: {', '.join(missing_data)}")
                rap_errors.append({'code': 'RAP_22', 'detail': f"Missing: {', '.join(missing_data)}"})

        # Validate IMSI format (should be 15 digits)
        imsi = record.get('imsi', '')
        if imsi and (not imsi.isdigit() or len(imsi) > 15):
            errors.append(f"Invalid IMSI format: {imsi}")
            rap_errors.append({'code': 'RAP_40', 'detail': f"Invalid IMSI: {imsi}"})

        # Validate record_type
        if record_type and record_type not in TAP_RECORD_TYPES:
            errors.append(f"Unknown record type: {record_type}")
            rap_errors.append({'code': 'RAP_10', 'detail': f"Unknown type: {record_type}"})

        if errors:
            self.invalid_count.inc()
            yield beam.pvalue.TaggedOutput('invalid', {
                'record': record,
                'validation_errors': errors,
                'rap_errors': rap_errors,
                'error_type': 'TAP_VALIDATION_ERROR',
                'timestamp': datetime.utcnow().isoformat(),
            })
        else:
            self.valid_count.inc()
            yield beam.pvalue.TaggedOutput('valid', record)


class IOTRateApplicator(beam.DoFn):
    """Apply Inter-Operator Tariff (IOT) rates to TAP records.

    In production, IOT rates would be loaded from a partner agreement
    database as a side input, keyed by (partner_id, service_type, effective_date).
    """

    def __init__(self, iot_rates=None):
        self.iot_rates = iot_rates or DEFAULT_IOT_RATES
        self.rated_count = Metrics.counter(self.__class__, 'iot_rated_records')
        self.unrated_count = Metrics.counter(self.__class__, 'iot_unrated_records')

    def process(self, record):
        record_type = record.get('record_type', '').upper()
        rate_config = self.iot_rates.get(record_type)

        if not rate_config:
            self.unrated_count.inc()
            record['iot_charge'] = 0.0
            record['iot_rate_applied'] = False
            yield record
            return

        self.rated_count.inc()
        record['iot_rate_applied'] = True

        try:
            if 'per_second' in rate_config:
                # Voice rating: per-second + setup fee
                duration = Decimal(str(record.get('duration', 0)))
                charge = duration * rate_config['per_second'] + rate_config.get('setup_fee', Decimal('0'))
                record['iot_charge'] = float(charge.quantize(Decimal('0.000001'), rounding=ROUND_HALF_UP))
                record['iot_rate_type'] = 'per_second'
                record['iot_rate_value'] = float(rate_config['per_second'])

            elif 'per_event' in rate_config:
                # Event-based rating (SMS, MMS)
                charge = rate_config['per_event']
                record['iot_charge'] = float(charge.quantize(Decimal('0.000001'), rounding=ROUND_HALF_UP))
                record['iot_rate_type'] = 'per_event'
                record['iot_rate_value'] = float(rate_config['per_event'])

            elif 'per_kb' in rate_config:
                # Data rating: per-KB
                volume_bytes = Decimal(str(record.get('data_volume_bytes', 0)))
                volume_kb = volume_bytes / Decimal('1024')
                charge = volume_kb * rate_config['per_kb']
                record['iot_charge'] = float(charge.quantize(Decimal('0.000001'), rounding=ROUND_HALF_UP))
                record['iot_rate_type'] = 'per_kb'
                record['iot_rate_value'] = float(rate_config['per_kb'])

            else:
                record['iot_charge'] = 0.0

        except (InvalidOperation, ValueError, TypeError) as e:
            logger.warning("IOT rating error for record %s: %s", record.get('tap_record_id'), e)
            record['iot_charge'] = 0.0
            record['iot_rate_error'] = str(e)

        yield record


class CurrencyConverter(beam.DoFn):
    """Convert charges to settlement currency (SDR by default).

    In production, exchange rates would be sourced from a daily FX feed
    (e.g., ECB, IMF) loaded as a side input keyed by (currency, date).
    """

    def __init__(self, settlement_currency='SDR', exchange_rates=None):
        self.settlement_currency = settlement_currency
        self.exchange_rates = exchange_rates or DEFAULT_EXCHANGE_RATES
        self.converted_count = Metrics.counter(self.__class__, 'currency_converted')
        self.conversion_errors = Metrics.counter(self.__class__, 'currency_errors')

    def process(self, record):
        source_currency = record.get('charge_currency', 'USD').upper()
        iot_charge = record.get('iot_charge', 0.0)

        try:
            source_rate = self.exchange_rates.get(source_currency)
            target_rate = self.exchange_rates.get(self.settlement_currency)

            if source_rate and target_rate:
                # Convert: source -> USD -> settlement currency
                usd_amount = Decimal(str(iot_charge)) * Decimal(str(source_rate))
                settlement_amount = usd_amount / Decimal(str(target_rate))
                record['settlement_amount'] = float(
                    settlement_amount.quantize(Decimal('0.000001'), rounding=ROUND_HALF_UP)
                )
                record['settlement_currency'] = self.settlement_currency
                record['exchange_rate_used'] = float(Decimal(str(source_rate)) / Decimal(str(target_rate)))
                self.converted_count.inc()
            else:
                # Cannot convert - keep original
                record['settlement_amount'] = iot_charge
                record['settlement_currency'] = source_currency
                record['exchange_rate_used'] = 1.0
                record['_fx_warning'] = f"No rate for {source_currency} or {self.settlement_currency}"
                self.conversion_errors.inc()

        except (InvalidOperation, ValueError, TypeError) as e:
            record['settlement_amount'] = iot_charge
            record['settlement_currency'] = source_currency
            record['_fx_error'] = str(e)
            self.conversion_errors.inc()

        yield record


class SettlementCalculator(beam.DoFn):
    """Calculate final settlement amounts with tax and adjustments.

    Groups records by partner and billing period to compute settlement totals.
    """

    def __init__(self):
        self.settlements_calculated = Metrics.counter(self.__class__, 'settlements_calculated')

    def process(self, element):
        key, records = element
        records_list = list(records)
        self.settlements_calculated.inc()

        partner_id, billing_period = key.split('|', 1) if '|' in key else (key, 'unknown')

        total_settlement = sum(r.get('settlement_amount', 0) for r in records_list)
        total_iot = sum(r.get('iot_charge', 0) for r in records_list)
        record_count = len(records_list)

        # Breakdown by service type
        by_service = {}
        for r in records_list:
            svc = r.get('record_type', 'UNKNOWN')
            if svc not in by_service:
                by_service[svc] = {'count': 0, 'amount': 0.0}
            by_service[svc]['count'] += 1
            by_service[svc]['amount'] += r.get('settlement_amount', 0)

        yield {
            'partner_id': partner_id,
            'billing_period': billing_period,
            'settlement_currency': records_list[0].get('settlement_currency', 'SDR') if records_list else 'SDR',
            'total_settlement_amount': round(total_settlement, 6),
            'total_iot_charge': round(total_iot, 6),
            'record_count': record_count,
            'service_breakdown': json.dumps(by_service),
            'settlement_date': datetime.utcnow().strftime('%Y-%m-%d'),
            '_processing_timestamp': datetime.utcnow().isoformat(),
            '_source_pipeline': '{{ pipeline.name }}',
        }

        # Also emit individual rated records for detail table
        for r in records_list:
            r['_processing_timestamp'] = datetime.utcnow().isoformat()
            yield beam.pvalue.TaggedOutput('details', r)


class RAPErrorGenerator(beam.DoFn):
    """Generate RAP (Returned Account Procedure) error records.

    RAP files are sent back to the originating partner when TAP records
    fail validation, per GSMA BA.13 / TD.32 specifications.
    """

    def __init__(self):
        self.rap_errors_generated = Metrics.counter(self.__class__, 'rap_errors_generated')

    def process(self, error_record):
        self.rap_errors_generated.inc()
        rap_errors = error_record.get('rap_errors', [])
        source_record = error_record.get('record', {})

        rap_file_record = {
            'rap_sequence_number': None,  # Assigned by downstream RAP file builder
            'sender_id': '{{ pipeline.source_vendor.value if pipeline.source_vendor else "UNKNOWN" }}',
            'recipient_id': source_record.get('partner_id', 'UNKNOWN'),
            'rap_file_creation_timestamp': datetime.utcnow().isoformat(),
            'original_tap_file_id': source_record.get('tap_file_id', ''),
            'original_record_type': source_record.get('record_type', ''),
            'original_imsi': source_record.get('imsi', ''),
            'original_call_timestamp': source_record.get('call_timestamp', ''),
            'error_count': len(rap_errors),
            'error_details': json.dumps(rap_errors),
            'rap_error_codes': ','.join(e.get('code', '') for e in rap_errors),
            'severity': 'FATAL' if any(
                e.get('code', '').startswith('RAP_5') for e in rap_errors
            ) else 'REJECT',
            '_source_pipeline': '{{ pipeline.name }}',
            '_processing_timestamp': datetime.utcnow().isoformat(),
        }

        yield rap_file_record


def run(argv=None):
    parser = argparse.ArgumentParser()
    parser.add_argument('--input_path', required=True,
                        help='GCS path pattern to TAP files')
    parser.add_argument('--output_table', required=True,
                        help='BigQuery settlement summary table (project:dataset.table)')
    parser.add_argument('--detail_table', default=None,
                        help='BigQuery rated detail table')
    parser.add_argument('--rap_output_table', default=None,
                        help='BigQuery RAP error output table')
    parser.add_argument('--dead_letter_table', default=None,
                        help='BigQuery dead letter table')
    parser.add_argument('--settlement_currency', default='SDR',
                        help='Settlement currency code (default: SDR)')
    parser.add_argument('--partner_config', default=None,
                        help='GCS path to partner IOT rate configuration')
    parser.add_argument('--temp_location', required=True, help='GCS temp location')
    known_args, pipeline_args = parser.parse_known_args(argv)

    options = PipelineOptions(pipeline_args)
    options.view_as(StandardOptions).runner = options.view_as(StandardOptions).runner or 'DataflowRunner'

    with beam.Pipeline(options=options) as p:
        # Parse TAP records
        parsed = (
            p
            | "ReadTAPFiles" >> beam.io.ReadFromText(known_args.input_path)
            | "ParseTAPRecords" >> beam.ParDo(TAPRecordParser()).with_outputs('parsed', 'errors')
        )

        # Validate
        validated = (
            parsed.parsed
            | "ValidateTAP" >> beam.ParDo(TAPValidator()).with_outputs('valid', 'invalid')
        )

        # Apply IOT rates
        rated = (
            validated.valid
            | "ApplyIOTRates" >> beam.ParDo(IOTRateApplicator())
        )

        # Convert currency
        converted = (
            rated
            | "ConvertCurrency" >> beam.ParDo(
                CurrencyConverter(settlement_currency=known_args.settlement_currency)
            )
        )

        # Calculate settlements grouped by partner and billing period
        settlements = (
            converted
            | "KeyByPartnerPeriod" >> beam.Map(
                lambda r: (
                    r.get('partner_id', 'UNKNOWN') + '|' + r.get('billing_period', 'UNKNOWN'),
                    r,
                )
            )
            | "GroupByPartner" >> beam.GroupByKey()
            | "CalculateSettlement" >> beam.ParDo(
                SettlementCalculator()
            ).with_outputs('details', main='summaries')
        )

        # Write settlement summaries
        settlements.summaries | "WriteSettlements" >> WriteToBigQuery(
            known_args.output_table,
            write_disposition=BigQueryDisposition.WRITE_APPEND,
            create_disposition=BigQueryDisposition.CREATE_NEVER,
            insert_retry_strategy='RETRY_ON_TRANSIENT_ERROR',
        )

        # Write rated detail records
        if known_args.detail_table:
            settlements.details | "WriteDetails" >> WriteToBigQuery(
                known_args.detail_table,
                write_disposition=BigQueryDisposition.WRITE_APPEND,
                create_disposition=BigQueryDisposition.CREATE_NEVER,
                insert_retry_strategy='RETRY_ON_TRANSIENT_ERROR',
            )

        # Generate RAP error files
        if known_args.rap_output_table:
            (
                validated.invalid
                | "GenerateRAPErrors" >> beam.ParDo(RAPErrorGenerator())
                | "WriteRAPErrors" >> WriteToBigQuery(
                    known_args.rap_output_table,
                    write_disposition=BigQueryDisposition.WRITE_APPEND,
                    create_disposition=BigQueryDisposition.CREATE_IF_NEEDED,
                )
            )

        # Dead letter queue for unparseable records
        if known_args.dead_letter_table:
            (
                parsed.errors
                | "WriteDeadLetters" >> WriteToBigQuery(
                    known_args.dead_letter_table,
                    write_disposition=BigQueryDisposition.WRITE_APPEND,
                    create_disposition=BigQueryDisposition.CREATE_IF_NEEDED,
                )
            )


if __name__ == "__main__":
    logging.basicConfig(level=logging.INFO)
    run()
