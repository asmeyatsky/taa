-- =============================================================================
-- Azure Synapse Analytics DDL for {{ dataset_name }}
-- Domain: {{ domain }}
-- Generated by TAA (Telco Analytics Accelerator)
-- =============================================================================

{% for table in tables %}
CREATE TABLE [{{ dataset_name }}].[{{ table.name }}]
(
{% for col in table.columns %}
  [{{ col.name }}] {{ col.bigquery_type.value | replace('INT64', 'BIGINT') | replace('FLOAT64', 'FLOAT') | replace('NUMERIC', 'DECIMAL(38,9)') | replace('BIGNUMERIC', 'DECIMAL(38,18)') | replace('BOOL', 'BIT') | replace('STRING', 'NVARCHAR(4000)') | replace('BYTES', 'VARBINARY(MAX)') | replace('GEOGRAPHY', 'GEOGRAPHY') | replace('JSON', 'NVARCHAR(MAX)') | replace('STRUCT', 'NVARCHAR(MAX)') }}{% if not col.nullable %} NOT NULL{% endif %}{% if not loop.last %},{% endif %}

{% endfor %}
)
WITH
(
{% if table.partitioning %}
  DISTRIBUTION = HASH({{ table.columns[0].name }}),
  PARTITION ({{ table.partitioning.column_name }} RANGE RIGHT FOR VALUES ())
{% else %}
  DISTRIBUTION = ROUND_ROBIN
{% endif %}
{% if table.clustering %}
  , CLUSTERED COLUMNSTORE INDEX
{% endif %}
);

{% endfor %}
