// =============================================================================
// Azure Bicep Template
// Generated by TAA (Telco Analytics Accelerator)
// =============================================================================

param location string = '{{ region }}'
param projectName string = '{{ project_id }}'
param environment string = 'production'

// Storage Account
resource storageAccount 'Microsoft.Storage/storageAccounts@2023-01-01' = {
  name: '${replace(projectName, '-', '')}taa'
  location: location
  sku: { name: 'Standard_LRS' }
  kind: 'StorageV2'
  properties: {
    minimumTlsVersion: 'TLS1_2'
    supportsHttpsTrafficOnly: true
    encryption: {
      services: {
        blob: { enabled: true }
        file: { enabled: true }
      }
      keySource: 'Microsoft.Storage'
    }
  }
}

// Synapse Workspace
resource synapseWorkspace 'Microsoft.Synapse/workspaces@2021-06-01' = {
  name: '${projectName}-synapse'
  location: location
  identity: { type: 'SystemAssigned' }
  properties: {
    defaultDataLakeStorage: {
      accountUrl: storageAccount.properties.primaryEndpoints.dfs
      filesystem: 'taa-data'
    }
{% if has_residency_requirement %}
    publicNetworkAccess: 'Disabled'
{% endif %}
  }
}

// Dedicated SQL Pool
resource sqlPool 'Microsoft.Synapse/workspaces/sqlPools@2021-06-01' = {
  parent: synapseWorkspace
  name: '${projectName}pool'
  location: location
  sku: { name: 'DW100c' }
  properties: { collation: 'SQL_Latin1_General_CP1_CI_AS' }
}

{% for dataset in datasets %}
{% if dataset.requires_encryption() %}
// Key Vault for {{ dataset.name }}
resource keyVault{{ loop.index }} 'Microsoft.KeyVault/vaults@2023-02-01' = {
  name: '${projectName}-kv-{{ loop.index }}'
  location: location
  properties: {
    sku: { family: 'A', name: 'standard' }
    tenantId: subscription().tenantId
    enableSoftDelete: true
    softDeleteRetentionInDays: 90
    enablePurgeProtection: true
  }
}
{% endif %}
{% endfor %}
