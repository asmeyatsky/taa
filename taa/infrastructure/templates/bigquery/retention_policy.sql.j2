-- =============================================================================
-- Data Retention Policy Enforcement
-- Generated by TAA (Telco Analytics Accelerator)
-- Jurisdiction: {{ jurisdiction }} ({{ framework }})
-- =============================================================================

{% for table_policy in retention_policies %}
-- {{ table_policy.table_name }}: {{ table_policy.retention_months }} months retention
{% if table_policy.partition_column %}
-- Delete partitions older than retention period
DELETE FROM `{{ project_id }}.{{ table_policy.dataset_name }}.{{ table_policy.table_name }}`
WHERE {{ table_policy.partition_column }} < DATE_SUB(CURRENT_DATE(), INTERVAL {{ table_policy.retention_months }} MONTH);
{% endif %}

{% endfor %}

