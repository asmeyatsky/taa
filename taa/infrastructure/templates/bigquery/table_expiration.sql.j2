-- =============================================================================
-- BigQuery Table Partition Expiration Configuration
-- Generated by TAA (Telco Analytics Accelerator)
-- =============================================================================

{% for table_policy in retention_policies %}
{% if table_policy.partition_column %}
ALTER TABLE `{{ project_id }}.{{ table_policy.dataset_name }}.{{ table_policy.table_name }}`
SET OPTIONS (
  partition_expiration_days = {{ table_policy.retention_months * 30 }},
  description = "Retention: {{ table_policy.retention_months }} months per {{ table_policy.framework }} ({{ table_policy.jurisdiction }}). Auto-expires partitions."
);
{% endif %}

{% endfor %}
