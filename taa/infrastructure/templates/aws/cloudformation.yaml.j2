# =============================================================================
# AWS CloudFormation Template
# Generated by TAA (Telco Analytics Accelerator)
# =============================================================================
AWSTemplateFormatVersion: '2010-09-09'
Description: 'TAA Telco Analytics Infrastructure'

Parameters:
  Environment:
    Type: String
    Default: production
    AllowedValues: [production, staging, development]
  ProjectName:
    Type: String
    Default: '{{ project_id }}'

Resources:
{% for dataset in datasets %}
  {{ dataset.name | replace('_', '') }}RedshiftSchema:
    Type: AWS::Redshift::ClusterSubnetGroup
    Properties:
      Description: '{{ dataset.telco_domain.value }} domain schema'

{% if dataset.requires_encryption() %}
  {{ dataset.name | replace('_', '') }}KMSKey:
    Type: AWS::KMS::Key
    Properties:
      Description: 'Encryption key for {{ dataset.name }}'
      EnableKeyRotation: true
      KeyPolicy:
        Version: '2012-10-17'
        Statement:
          - Sid: Enable IAM User Permissions
            Effect: Allow
            Principal:
              AWS: !Sub 'arn:aws:iam::${AWS::AccountId}:root'
            Action: 'kms:*'
            Resource: '*'
{% endif %}

{% endfor %}
  StagingBucket:
    Type: AWS::S3::Bucket
    Properties:
      BucketName: !Sub '${ProjectName}-taa-staging'
      BucketEncryption:
        ServerSideEncryptionConfiguration:
          - ServerSideEncryptionByDefault:
              SSEAlgorithm: aws:kms
      VersioningConfiguration:
        Status: Enabled
      LifecycleConfiguration:
        Rules:
          - Id: CleanupRule
            Status: Enabled
            ExpirationInDays: 30

  GlueDatabase:
    Type: AWS::Glue::Database
    Properties:
      CatalogId: !Ref AWS::AccountId
      DatabaseInput:
        Name: !Sub '${ProjectName}_analytics'
        Description: 'TAA Analytics Database'

Outputs:
  StagingBucketArn:
    Value: !GetAtt StagingBucket.Arn
