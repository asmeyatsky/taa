-- =============================================================================
-- Amazon Redshift DDL for {{ dataset_name }}
-- Domain: {{ domain }}
-- Generated by TAA (Telco Analytics Accelerator)
-- =============================================================================

{% for table in tables %}
CREATE TABLE IF NOT EXISTS {{ dataset_name }}.{{ table.name }}
(
{% for col in table.columns %}
  {{ col.name }} {{ col.bigquery_type.value | replace('INT64', 'BIGINT') | replace('FLOAT64', 'DOUBLE PRECISION') | replace('NUMERIC', 'DECIMAL(38,9)') | replace('BIGNUMERIC', 'DECIMAL(76,38)') | replace('BOOL', 'BOOLEAN') | replace('STRING', 'VARCHAR(4096)') | replace('BYTES', 'VARBYTE(65535)') | replace('GEOGRAPHY', 'GEOMETRY') | replace('JSON', 'SUPER') | replace('STRUCT', 'SUPER') }}{% if not col.nullable %} NOT NULL{% endif %}{% if col.description %} -- {{ col.description }}{% endif %}{% if not loop.last %},{% endif %}

{% endfor %}
)
{% if table.partitioning %}
-- Partitioning equivalent: use Redshift DISTSTYLE and SORTKEY
DISTSTYLE KEY
DISTKEY ({{ table.columns[0].name }})
COMPOUND SORTKEY ({{ table.partitioning.column_name }}{% if table.clustering %}, {{ table.clustering.column_names | join(", ") }}{% endif %})
{% endif %}
;

{% endfor %}
