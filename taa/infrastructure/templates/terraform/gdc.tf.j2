{# Google Distributed Cloud (GDC) - Edge / sovereign on-premise resources #}
# =============================================================================
# GDC (Google Distributed Cloud) Configuration
# Generated by Telco Analytics Accelerator
# =============================================================================

# -----------------------------------------------------------------------------
# Edge Container Cluster
# -----------------------------------------------------------------------------
resource "google_edgecontainer_cluster" "taa_edge" {
  name     = "taa-edge-cluster"
  project  = var.project_id
  location = var.region

  authorization {
    admin_users {
      username = "admin@${var.project_id}.iam.gserviceaccount.com"
    }
  }

  networking {
    cluster_ipv4_cidr_blocks  = ["10.0.0.0/16"]
    services_ipv4_cidr_blocks = ["10.1.0.0/16"]
  }

{% if has_residency_requirement %}
  # Sovereign controls – keep all data processing on-premise
  control_plane {
    local {
      # Control plane runs on the edge nodes for data sovereignty
    }
  }
{% endif %}

  labels = {
    managed_by = "taa"
    purpose    = "telco-analytics-edge"
  }
}

# -----------------------------------------------------------------------------
# Edge Container Node Pool
# -----------------------------------------------------------------------------
resource "google_edgecontainer_node_pool" "taa_edge_workers" {
  name                 = "taa-edge-workers"
  project              = var.project_id
  location             = var.region
  cluster              = google_edgecontainer_cluster.taa_edge.name
  node_count           = 3
  node_location        = var.region

  labels = {
    managed_by = "taa"
    role       = "analytics-worker"
  }
}

# -----------------------------------------------------------------------------
# BigQuery Omni / BigLake External Connections
# -----------------------------------------------------------------------------
{% for dataset in datasets %}
resource "google_bigquery_connection" "{{ dataset.name }}_external" {
  connection_id = "{{ dataset.name }}-biglake-conn"
  project       = var.project_id
  location      = "{{ dataset.gcp_region | upper }}"
  friendly_name = "{{ dataset.name }} BigLake connection"
  description   = "BigLake external connection for {{ dataset.telco_domain.value }} domain (GDC)"

  cloud_resource {}
}

resource "google_bigquery_dataset" "{{ dataset.name }}_omni" {
  dataset_id    = "{{ dataset.name }}_omni"
  friendly_name = "{{ dataset.name }} (BigQuery Omni)"
  description   = "BigQuery Omni external dataset for {{ dataset.telco_domain.value }} domain on GDC"
  location      = "{{ dataset.gcp_region | upper }}"
  project       = var.project_id

  external_dataset_reference {
    external_source = google_bigquery_connection.{{ dataset.name }}_external.name
    connection      = google_bigquery_connection.{{ dataset.name }}_external.name
  }

  labels = {
    domain     = "{{ dataset.telco_domain.value }}"
    managed_by = "taa"
    runtime    = "gdc"
  }
}

{% endfor %}

# -----------------------------------------------------------------------------
# VPC Peering for On-Premise Connectivity
# -----------------------------------------------------------------------------
resource "google_compute_network" "taa_gdc_network" {
  name                    = "taa-gdc-onprem-network"
  project                 = var.project_id
  auto_create_subnetworks = false
}

resource "google_compute_subnetwork" "taa_gdc_subnet" {
  name          = "taa-gdc-onprem-subnet"
  project       = var.project_id
  region        = var.region
  network       = google_compute_network.taa_gdc_network.id
  ip_cidr_range = "10.100.0.0/20"
}

resource "google_compute_network_peering" "taa_gdc_peering" {
  name         = "taa-gdc-onprem-peering"
  network      = google_compute_network.taa_gdc_network.self_link
  peer_network = "projects/${var.project_id}/global/networks/onprem-network"

  export_custom_routes = true
  import_custom_routes = true
}

resource "google_compute_firewall" "taa_gdc_allow_internal" {
  name    = "taa-gdc-allow-internal"
  project = var.project_id
  network = google_compute_network.taa_gdc_network.name

  allow {
    protocol = "tcp"
    ports    = ["443", "8443", "9090"]
  }

  source_ranges = ["10.100.0.0/20", "10.0.0.0/16"]

  target_tags = ["taa-gdc"]
}

# -----------------------------------------------------------------------------
# Sovereign Controls Configuration
# -----------------------------------------------------------------------------
{% if has_residency_requirement %}
resource "google_org_policy_policy" "taa_resource_locations" {
  name   = "projects/${var.project_id}/policies/gcp.resourceLocations"
  parent = "projects/${var.project_id}"

  spec {
    rules {
      values {
        allowed_values = ["in:{{ region }}-locations"]
      }
    }
  }
}

resource "google_org_policy_policy" "taa_restrict_vpc_peering" {
  name   = "projects/${var.project_id}/policies/compute.restrictVpcPeering"
  parent = "projects/${var.project_id}"

  spec {
    rules {
      values {
        allowed_values = [
          "under:projects/${var.project_id}",
        ]
      }
    }
  }
}

resource "google_org_policy_policy" "taa_disable_serial_port" {
  name   = "projects/${var.project_id}/policies/compute.disableSerialPortAccess"
  parent = "projects/${var.project_id}"

  spec {
    rules {
      enforce = "TRUE"
    }
  }
}

resource "google_access_context_manager_service_perimeter" "taa_gdc_perimeter" {
  parent = "accessPolicies/${var.access_policy_id}"
  name   = "accessPolicies/${var.access_policy_id}/servicePerimeters/taa_gdc_perimeter"
  title  = "TAA GDC Sovereign Perimeter"

  status {
    restricted_services = [
      "bigquery.googleapis.com",
      "storage.googleapis.com",
      "bigqueryconnection.googleapis.com",
      "edgecontainer.googleapis.com",
    ]

    resources = [
      "projects/${var.project_number}",
    ]

    vpc_accessible_services {
      enable_restriction = true
      allowed_services = [
        "bigquery.googleapis.com",
        "storage.googleapis.com",
      ]
    }
  }
}
{% endif %}
