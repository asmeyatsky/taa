{# IAM configuration for BigQuery datasets #}
{% for dataset in datasets %}
resource "google_bigquery_dataset_iam_member" "{{ dataset.name }}_viewer" {
  dataset_id = google_bigquery_dataset.{{ dataset.name }}.dataset_id
  role       = "roles/bigquery.dataViewer"
  member     = "serviceAccount:${var.data_viewer_sa}"
}

resource "google_bigquery_dataset_iam_member" "{{ dataset.name }}_editor" {
  dataset_id = google_bigquery_dataset.{{ dataset.name }}.dataset_id
  role       = "roles/bigquery.dataEditor"
  member     = "serviceAccount:${var.data_editor_sa}"
}

{% endfor %}
