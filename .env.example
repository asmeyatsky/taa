# TAA Environment Configuration
# Copy to .env and customize before running

# REQUIRED: Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
TAA_SECRET_KEY=

# Environment: "development" or "production"
# Production mode: requires TAA_SECRET_KEY, disables demo users, sets 30min token expiry
TAA_ENV=development

# JWT token expiry in minutes (default: 30 in production, 480 in development)
TAA_TOKEN_EXPIRE_MINUTES=

# Database URL (default: sqlite:///./taa.db)
TAA_DATABASE_URL=sqlite:///./taa.db

# Optional: Anthropic API key for LLM-powered schema mapping
ANTHROPIC_API_KEY=

# Logging level (DEBUG, INFO, WARNING, ERROR)
TAA_LOG_LEVEL=INFO

# Rate limiting (set to "false" to disable)
TAA_RATE_LIMIT_ENABLED=true

# Set to "true" to disable demo user seeding even in development
TAA_DISABLE_DEMO_USERS=false
